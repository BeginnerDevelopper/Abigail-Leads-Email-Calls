        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"phone_number\": \"{{ $json.Phone }}\",\n  \"task\": \"You are Abigail, a friendly and professional outreach specialist calling on behalf of Genius Astra, an AI automation agency based in New York. You are calling {{ $json.Company }} to introduce our AI automation services and explore if they would benefit from streamlining their business operations.\\n\\nYour goal:\\n1. Greet the person warmly and introduce yourself.\\n2. Ask if they are the owner or decision maker.\\n3. Briefly explain that Genius Astra helps businesses like theirs eliminate repetitive tasks, save time, and scale using AI automation.\\n4. Ask about their current biggest operational challenge.\\n5. Based on their response, propose a free 15-minute discovery call with our team.\\n6. If they agree, ask for their preferred date and time.\\n7. If they are not interested, thank them politely and end the call.\\n8. Always be respectful, concise, and never pushy.\\n\\nKey rules:\\n- Never lie or make promises you cannot keep.\\n- If they already have automation, acknowledge it and ask what tools they use.\\n- If they ask technical questions you cannot answer, say the team will clarify on the discovery call.\\n- Keep the call under 10 minutes.\",\n  \"voice\": \"7c4ffd1b-22d0-49ff-9fd6-b43fafc87908\",\n  \"wait_for_greeting\": false,\n  \"record\": true,\n  \"answered_by_enabled\": true,\n  \"noise_cancellation\": false,\n  \"interruption_threshold\": 500,\n  \"block_interruptions\": false,\n  \"max_duration\": 12,\n  \"model\": \"base\",\n  \"language\": \"babel-en\",\n  \"background_track\": \"none\",\n  \"voicemail_action\": \"hangup\",\n  \"temperature\": 0.5,\n  \"webhook\": \"https://solubly-penceless-ellis.ngrok-free.dev/webhook-test/bland-ai-post-call\",\n  \"webhook_events\": [\"call_ended\"],\n  \"summary_prompt\": \"Generate a concise post-call summary in English. Include: 1) Business name, category and location if mentioned. 2) Interest level in Genius Astra AI automation services, specify if they already have an automation solution. 3) Key pain points discussed. 4) Objections raised. 5) Agreed next step: discovery call booked with date and time, requested more info, follow up later, or do not contact. 6) Tone of conversation. Keep it factual and based strictly on the transcript.\",\n  \"analysis_schema\": {\n    \"type\": \"object\",\n    \"properties\": {\n      \"interested\": {\n        \"type\": \"string\",\n        \"enum\": [\"yes\", \"no\", \"has_automation\"],\n        \"description\": \"Whether the business is interested. yes=interested, no=not interested, has_automation=already has automation.\"\n      },\n      \"follow_up\": {\n        \"type\": \"string\",\n        \"enum\": [\"book_call\", \"send_information\", \"follow_up_later\", \"dont_contact\"],\n        \"description\": \"Agreed next step after the call.\"\n      }\n    },\n    \"required\": [\"interested\", \"follow_up\"]\n  },\n  \"metadata\": {\n    \"lead_id\": \"{{ $json.lead_id }}\",\n    \"company\": \"{{ $json.Company }}\"\n  },\n  \"request_data\": {\n    \"first_name\": \"{{ $json.Company }}\",\n    \"email\": \"{{ $json.Email }}\",\n    \"service\": \"AI Automation\"\n  },\n  \"json_mode_enabled\": false\n}",
