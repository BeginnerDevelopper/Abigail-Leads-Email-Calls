        "sendTo": "={{ $json.data.responses.email }}",
        "subject": "=Appointment Confirmed: Your AI Automation Meeting with Genius Astra for {{ $('VAPI Post-Call Webhook').item.json.body.message.assistant.metadata.company }}",
        "message": "=<!DOCTYPE html>\n<html>\n<head>\n  <meta charset=\"UTF-8\">\n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1\">\n  <title>Appointment Confirmation – Genius Astra</title>\n</head>\n<body style=\"margin:0;padding:0;background:#f4f4f4;font-family:Arial,sans-serif;font-size:14px;color:#222222;line-height:1.7;\">\n  <table width=\"100%\" cellpadding=\"0\" cellspacing=\"0\" border=\"0\" style=\"background:#f4f4f4;padding:32px 0;\">\n    <tr>\n      <td align=\"center\">\n        <table width=\"560\" cellpadding=\"0\" cellspacing=\"0\" border=\"0\" style=\"max-width:560px;background:#ffffff;border-radius:6px;overflow:hidden;border:1px solid #e0e0e0;\">\n\n          <!-- HEADER -->\n          <tr>\n            <td style=\"background:#111111;padding:20px 28px 18px 28px;\">\n              <table width=\"100%\" cellpadding=\"0\" cellspacing=\"0\" border=\"0\">\n                <tr>\n                  <td>\n                    <p style=\"margin:0;font-size:11px;font-weight:700;color:#F5C518;letter-spacing:2px;text-transform:uppercase;\">Genius Astra</p>\n                    <p style=\"margin:4px 0 0 0;font-size:20px;font-weight:700;color:#ffffff;letter-spacing:0.3px;\">Appointment Confirmed ✓</p>\n                  </td>\n                  <td align=\"right\">\n                    <div style=\"background:#F5C518;border-radius:50%;width:44px;height:44px;text-align:center;line-height:44px;font-size:20px;\">📅</div>\n                  </td>\n                </tr>\n              </table>\n            </td>\n          </tr>\n\n          <!-- GOLD LINE -->\n          <tr><td style=\"background:#F5C518;height:3px;font-size:0;line-height:0;\">&nbsp;</td></tr>\n\n          <!-- BODY -->\n          <tr>\n            <td style=\"padding:28px 28px 8px 28px;\">\n\n              <p style=\"margin:0 0 16px 0;\">Hi <strong>{{ $('Conversion ISO').item.json.company }}</strong>,</p>\n\n              <p style=\"margin:0 0 16px 0;\">\n                Thank you for your time today! It was a pleasure discussing how <strong>Genius Astra</strong>'s\n                AI solutions can drive growth and efficiency for <strong>{{ $('Conversion ISO').item.json.company }}</strong>.\n              </p>\n\n              <p style=\"margin:0 0 16px 0;\">\n                This email confirms your upcoming meeting. We'll dive deeper into your needs and explore\n                the best AI automation strategies for your business. Here are your meeting details:\n              </p>\n\n              <!-- MEETING DETAILS CARD -->\n              <table width=\"100%\" cellpadding=\"0\" cellspacing=\"0\" border=\"0\"\n                     style=\"background:#f9f9f9;border:1px solid #eeeeee;border-radius:6px;margin:0 0 20px 0;\">\n                <tr>\n                  <td style=\"padding:18px 20px;\">\n                    <table width=\"100%\" cellpadding=\"0\" cellspacing=\"0\" border=\"0\">\n                      <tr>\n                        <td style=\"padding:6px 0;border-bottom:1px solid #eeeeee;\">\n                          <span style=\"font-size:12px;color:#888888;text-transform:uppercase;letter-spacing:0.5px;\">Date</span><br>\n                          <strong style=\"color:#111111;\">{{ DateTime.fromISO($('Conversion ISO').item.json.startTimeIso).setZone('America/New_York').toFormat('MMMM dd, yyyy') }}</strong>\n                        </td>\n                      </tr>\n                      <tr>\n                        <td style=\"padding:6px 0;border-bottom:1px solid #eeeeee;\">\n                          <span style=\"font-size:12px;color:#888888;text-transform:uppercase;letter-spacing:0.5px;\">Time</span><br>\n                          <strong style=\"color:#111111;\">{{ DateTime.fromISO($('Conversion ISO').item.json.startTimeIso).setZone('America/New_York').toFormat('h:mm a') }} Eastern Time</strong>\n                        </td>\n                      </tr>\n                      <tr>\n                        <td style=\"padding:6px 0;\">\n                          <span style=\"font-size:12px;color:#888888;text-transform:uppercase;letter-spacing:0.5px;\">Meeting Link</span><br>\n                          <a href=\"{{ $json.data.videoCallUrl }}\" style=\"color:#F5C518;font-weight:700;text-decoration:none;\">https://cal.com/geniusastra</a>\n                        </td>\n                      </tr>\n                    </table>\n                  </td>\n                </tr>\n              </table>\n\n              <p style=\"margin:0 0 20px 0;\">We look forward to seeing you soon!</p>\n\n              <!-- CTA BUTTON -->\n              <table cellpadding=\"0\" cellspacing=\"0\" border=\"0\" style=\"margin:0 0 28px 0;\">\n                <tr>\n                  <td style=\"background:#F5C518;border-radius:4px;\">\n                    <a href=\"{{ $json.data.videoCallUrl }}\"\n                       style=\"display:inline-block;padding:11px 26px;font-size:13px;font-weight:700;color:#111111;text-decoration:none;\">\n                      Join the Meeting &rarr;\n                    </a>\n                  </td>\n                </tr>\n              </table>\n\n            </td>\n          </tr>\n\n          <!-- DIVIDER -->\n          <tr><td style=\"padding:0 28px;\"><div style=\"border-top:1px solid #eeeeee;\"></div></td></tr>\n\n          <!-- GOLD LINE -->\n          <tr><td style=\"background:#F5C518;height:3px;font-size:0;line-height:0;\">&nbsp;</td></tr>\n\n          <!-- FIRMA -->\n          <tr>\n            <td style=\"background:#111111;padding:20px 24px 16px 24px;\">\n              <table width=\"100%\" cellpadding=\"0\" cellspacing=\"0\" border=\"0\">\n                <tr>\n                  <td style=\"vertical-align:top;padding-right:20px;\">\n                    <p style=\"margin:0 0 2px 0;font-size:17px;font-weight:700;color:#F5C518;letter-spacing:0.5px;line-height:1.2;\">Valeri Gutierrez</p>\n                    <p style=\"margin:0 0 10px 0;font-size:12px;color:#ffffff;letter-spacing:0.3px;\">Sales Advisor · Genius Astra</p>\n                    <p style=\"margin:0 0 3px 0;font-size:11px;color:#999999;\">📍 Queens, New York</p>\n                    <p style=\"margin:0 0 3px 0;font-size:11px;color:#999999;\">🌐 <a href=\"https://geniusastra.com\" style=\"color:#F5C518;text-decoration:none;\">geniusastra.com</a></p>\n                    <p style=\"margin:0;font-size:11px;color:#999999;\">📸 <a href=\"https://instagram.com/geniusastra\" style=\"color:#F5C518;text-decoration:none;\">@geniusastra</a></p>\n                  </td>\n                  <td style=\"border-left:1px solid #333333;padding:0 0 0 20px;vertical-align:top;\">\n                    <p style=\"margin:0 0 8px 0;font-size:9px;font-weight:700;color:#F5C518;letter-spacing:1px;text-transform:uppercase;\">Our Services</p>\n                    <table cellpadding=\"0\" cellspacing=\"0\" border=\"0\">\n                      <tr><td style=\"padding:0 0 4px 0;\"><span style=\"background:#1a1a1a;border:1px solid #333;color:#cccccc;font-size:10px;padding:2px 8px;border-radius:3px;\">⚡ AI Automation</span></td></tr>\n                      <tr><td style=\"padding:0 0 4px 0;\"><span style=\"background:#1a1a1a;border:1px solid #333;color:#cccccc;font-size:10px;padding:2px 8px;border-radius:3px;\">🌍 Global Multilingual Expansion</span></td></tr>\n                      <tr><td style=\"padding:0 0 4px 0;\"><span style=\"background:#1a1a1a;border:1px solid #333;color:#cccccc;font-size:10px;padding:2px 8px;border-radius:3px;\">✦ AI Branding</span></td></tr>\n                      <tr><td><span style=\"background:#1a1a1a;border:1px solid #333;color:#cccccc;font-size:10px;padding:2px 8px;border-radius:3px;\">🚀 Strategic Launch</span></td></tr>\n                    </table>\n                  </td>\n                </tr>\n              </table>\n            </td>\n          </tr>\n\n          <!-- CTA BANNER -->\n          <tr>\n            <td style=\"background:#F5C518;padding:10px 24px;\">\n              <table width=\"100%\" cellpadding=\"0\" cellspacing=\"0\" border=\"0\">\n                <tr>\n                  <td><p style=\"margin:0;font-size:11px;font-weight:700;color:#111111;\">📊 Want a FREE market analysis for your business?</p></td>\n                  <td style=\"text-align:right;white-space:nowrap;\">\n                    <a href=\"https://geniusastra.com\" style=\"background:#111111;color:#F5C518;font-size:10px;font-weight:700;padding:5px 12px;text-decoration:none;border-radius:3px;display:inline-block;\">Schedule Here &rarr;</a>\n                  </td>\n                </tr>\n              </table>\n            </td>\n          </tr>\n\n          <!-- FOOTER -->\n          <tr>\n            <td style=\"background:#0a0a0a;padding:10px 24px;\">\n              <p style=\"margin:0;font-size:9px;color:#555555;line-height:1.5;text-align:center;\">\n                This email and its attachments are confidential and intended exclusively for the indicated recipient.\n                &copy; 2026 Genius Astra &mdash;\n                <a href=\"https://geniusastra.com\" style=\"color:#555555;text-decoration:none;\">geniusastra.com</a>\n              </p>\n            </td>\n          </tr>\n\n          <!-- GOLD LINE BOTTOM -->\n          <tr><td style=\"background:#F5C518;height:2px;font-size:0;line-height:0;\">&nbsp;</td></tr>\n\n        </table>\n      </td>\n    </tr>\n  </table>\n</body>\n</html>",
