    {
      "parameters": {
        "jsCode": "const webhook = $(\"VAPI Post-Call Webhook\").item.json.body.message;\n\nconst callCreatedAt = webhook.call.createdAt;\nconst callTimeIso = callCreatedAt ? new Date(callCreatedAt).toISOString() : null;\n\nconst structuredOutputs = webhook.artifact?.structuredOutputs || {};\nconst callSummary = Object.values(structuredOutputs).find(v => v.name === \"Call Summary\");\n\n// result puede venir como STRING o como OBJETO — manejamos ambos\nlet results = {};\nconst raw = callSummary?.result;\nif (typeof raw === \"string\") {\n  try { results = JSON.parse(raw); } catch(e) { results = {}; }\n} else if (typeof raw === \"object\" && raw !== null) {\n  results = raw;\n}\n\n// Campos con o sin guion bajo — busca ambas variantes\nconst followUpDate = results.appointment_day  || results.appointmentday  || null;\nlet   followUpTime = results.appointment_time || results.appointmenttime || null;\n\n// Normaliza \"1100\" → \"11:00\" si falta el colon\nif (followUpTime && !followUpTime.includes(\":\")) {\n  followUpTime = followUpTime.slice(0, 2) + \":\" + followUpTime.slice(2);\n}\n\nlet startTimeIso = null;\nlet endTimeIso   = null;\n\nif (followUpDate && followUpTime) {\n  const startObj = new Date(`${followUpDate}T${followUpTime}:00-04:00`);\n  if (!isNaN(startObj.getTime())) {\n    startTimeIso = startObj.toISOString();\n    endTimeIso   = new Date(startObj.getTime() + 30 * 60 * 1000).toISOString();\n  }\n}\n\nconst metadata = webhook.call.assistantOverrides?.metadata || {};\n\nreturn [{\n  json: {\n    callTimeIso,\n    startTimeIso,\n    endTimeIso,\n    durationMinutes: 30,\n    lead_id:    metadata.lead_id   || metadata.leadid   || null,\n    company:    metadata.company   || results.company   || null,\n    email:      metadata.email     || null,\n    follow_up:  results.follow_up  || results.followup  || null,\n    interested: results.interested || null,\n    pain_point: results.pain_point || results.painpoint || null,\n  }\n}];"
      },
      "type": "n8n-nodes-base.code",
